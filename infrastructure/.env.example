# Database
DATABASE_URL=postgresql://notifyx:notifyx_secret@localhost:5432/notifyx_db
POSTGRES_USER=notifyx
POSTGRES_PASSWORD=notifyx_secret
POSTGRES_DB=notifyx_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

# Application
NODE_ENV=development
PORT=3000
API_VERSION=v1

# AI Worker
AI_WORKER_URL=http://ai-worker:8000

# Security
JWT_SECRET=change_this_to_a_real_random_secret_in_production
JWT_EXPIRES_IN=7d

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
